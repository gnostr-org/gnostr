#!/usr/bin/env bash
set -euo pipefail

BASH_VERSION_CURRENT="${BASH_VERSION:-unknown}"
BASH_MAJOR="${BASH_VERSINFO[0]:-0}"
BASH_MINOR="${BASH_VERSINFO[1]:-0}"
if ! bash -n "${BASH_SOURCE[0]}"; then
  exit 1
fi

DRY_RUN=false
POSITIONAL_ARGS=()
while (($#)); do
    case "$1" in
        -n|--dry-run)
            DRY_RUN=true
            ;;
        --dry-run)
            DRY_RUN=true
            ;;
        *)
            POSITIONAL_ARGS+=("$1")
            ;;
    esac
    shift
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ROOT_CARGO_TOML="$REPO_ROOT/Cargo.toml"
CHECK_TARGET_DIR="$(mktemp -d /tmp/gnostr-update-check.XXXXXX)"
cleanup() {
    rm -rf "$CHECK_TARGET_DIR"
}
trap cleanup EXIT

set_workspace_version() {
    local manifest="$1"
    local version="$2"

    SYNC_VERSION="$version" perl -0pi -e '
        my $v = $ENV{SYNC_VERSION};
        s/(\[workspace\.package\]\n(?:[^\[]*\n)*?)version\s*=\s*"[^"]+"/$1 . qq(version = "$v")/se
    ' "$manifest"
}

workspace_version() {
    perl -0ne 'print "$1\n" and exit if /\[workspace\.package\].*?^version\s*=\s*"([^"]+)"/ms' Cargo.toml
}

cd "$REPO_ROOT"

stage_cargo_files() {
    local paths=()
    while IFS= read -r -d '' path; do
        case "$path" in
            ./vendor/*|vendor/*) continue ;;
        esac
        paths+=("$path")
    done < <(
        find . \( -path './vendor' -o -path './target' \) -prune -o \( -name Cargo.lock -o -name Cargo.toml \) -print0
    )

    if [ "${#paths[@]}" -gt 0 ]; then
        git add -- "${paths[@]}"
    fi
}

if [ ! -f "$ROOT_CARGO_TOML" ]; then
    echo "Error: $ROOT_CARGO_TOML not found."
    exit 1
fi

if [ "$DRY_RUN" = true ]; then
    WORKSPACE_VERSION="$(workspace_version)"
    echo "Dry run: would run the update workflow."
    printf '%s\n' \
        "  gnostr git tag create" \
        "  update workspace package versions" \
        "  taplo format Cargo.toml and manifests" \
        "  cargo check -p gnostr-bins --locked --target-dir /tmp/gnostr-update-check.<tmp>" \
        "  cargo update --workspace" \
        "  gnostr legit -m \"v${WORKSPACE_VERSION}\" --prefix 000000" \
        "  cargo publish -j8"
    if [ "${#POSITIONAL_ARGS[@]}" -gt 0 ]; then
        exec "$SCRIPT_DIR/update_versions.sh" --dry-run "${POSITIONAL_ARGS[@]}"
    else
        exec "$SCRIPT_DIR/update_versions.sh" --dry-run
    fi
fi

git add scripts
stage_cargo_files

cargo check -p gnostr-bins --locked --target-dir "$CHECK_TARGET_DIR"

NEW_TAG="$(gnostr git tag create)"
NEW_VERSION="${NEW_TAG#v}"

set_workspace_version "$ROOT_CARGO_TOML" "$NEW_VERSION"
taplo format "$ROOT_CARGO_TOML"

stage_cargo_files
git add "$ROOT_CARGO_TOML"

if [ "${#POSITIONAL_ARGS[@]}" -gt 0 ]; then
    SKIP_VERSION_COMMIT=1 VERSION_TAG="$NEW_TAG" exec "$SCRIPT_DIR/update_versions.sh" "${POSITIONAL_ARGS[@]}"
else
    SKIP_VERSION_COMMIT=1 VERSION_TAG="$NEW_TAG" exec "$SCRIPT_DIR/update_versions.sh"
fi
